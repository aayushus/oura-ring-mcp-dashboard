{
  "name": "oura-ring-mcp",
  "version": "0.1.4",
  "mcpName": "io.github.mitchhankins01/oura-ring-mcp",
  "description": "MCP server for Oura Ring data with smart analysis tools",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3"
    ]
  },
  "main": "dist/index.js",
  "bin": {
    "oura-ring-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mitchhankins01/oura-ring-mcp.git"
  },
  "homepage": "https://github.com/mitchhankins01/oura-ring-mcp#readme",
  "bugs": {
    "url": "https://github.com/mitchhankins01/oura-ring-mcp/issues"
  },
  "scripts": {
    "build": "npm --prefix dashboard run build && tsc",
    "dev": "tsc --watch",
    "dev:inspect": "concurrently -n tsc,mcp -c blue,green \"pnpm dev\" \"pnpm inspect\"",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "inspect": "mcp-inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "update-openapi": "bash scripts/update-openapi-spec.sh",
    "generate-types": "npx openapi-typescript oura-openapi.json -o src/types/oura-api.ts",
    "update-types": "pnpm update-openapi && pnpm generate-types",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "oura",
    "oura-ring",
    "health",
    "sleep",
    "claude",
    "ai"
  ],
  "author": "Mitch Hankins",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@node-rs/argon2": "^2.0.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.19.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
