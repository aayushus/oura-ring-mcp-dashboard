# =============================================================================
# Oura MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You only need ONE auth method — Personal Access Token is simpler.
# OAuth is needed if you want automatic token refresh.
# =============================================================================

# -----------------------------------------------------------------------------
# AUTH METHOD 1: Personal Access Token (recommended for personal use)
# -----------------------------------------------------------------------------
# 1. Go to: https://cloud.ouraring.com/personal-access-tokens
# 2. Click "Create New Personal Access Token"
# 3. Give it a name (e.g. "mcp-server"), copy the token and paste below
# Note: Personal access tokens were deprecated in Dec 2025 — if this page
#       is unavailable, use OAuth below instead.
# -----------------------------------------------------------------------------
OURA_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# AUTH METHOD 2: OAuth2 (needed for token auto-refresh)
# -----------------------------------------------------------------------------
# 1. Go to: https://cloud.ouraring.com/oauth/applications
# 2. Click "Create New Application"
# 3. Set Redirect URI to: http://localhost:3000/callback
# 4. Copy the Client ID and Client Secret below
# 5. Run the auth flow: docker compose run --rm oura-mcp node dist/index.js auth
# -----------------------------------------------------------------------------
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# SERVER SETTINGS
# -----------------------------------------------------------------------------
# Port the MCP server listens on (default: 3000)
PORT=3000
